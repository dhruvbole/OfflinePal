<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="56dp"
    android:orientation="horizontal" android:gravity="center_vertical"
    android:paddingStart="16dp" android:paddingEnd="8dp">
    <TextView android:layout_width="32dp" android:layout_height="wrap_content"
        android:text="⏱" android:textSize="22sp" android:layout_marginEnd="12dp"/>
    <TextView android:id="@+id/text_timer_display" android:layout_width="0dp"
        android:layout_height="wrap_content" android:layout_weight="1"
        android:textSize="32sp" android:textStyle="bold" android:fontFamily="monospace"
        android:textColor="?attr/colorPrimary" android:text="00:00"/>
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_cancel_timer"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Cancel"/>
</LinearLayout>
